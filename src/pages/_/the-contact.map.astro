---
// PROPS *********************************************************************************************************************************
const { class: className } = Astro.props;

// TYPES *********************************************************************************************************************************
type Props = { class: string };
export type TheContactMapProps = Props;
---

<RootElement>
  <figure data-target="map" class={className}></figure>
</RootElement>

<script>
  RootElement.ready(async ($) => {
    const [L, { default: css }] = await Promise.all([import("leaflet"), import("leaflet/dist/leaflet.css")]);
    const { lat, lng, zoom } = { lat: -21.142_107, lng: 55.294_209, zoom: 17 };
    const map = L.map($<HTMLElement>("map")).setView([lat, lng], zoom);

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);
    L.marker([lat, lng], {
      icon: L.icon({
        iconSize: [25, 41],
        iconAnchor: [10, 41],
        popupAnchor: [2, -40],
        iconUrl: "/map/icon.png",
        iconRetinaUrl: "/map/icon2.png",
        shadowUrl: "/map/shadow.png",
      }),
    }).addTo(map);
  });
</script>
